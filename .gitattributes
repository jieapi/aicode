# 默认：文本文件按提交时的原样保存（不自动转 CRLF），checkout 时也不转换。
# 解决 commit 时反复出现的 "LF will be replaced by CRLF" 警告。
* text=auto eol=lf

# 明确文本类按 LF（跨平台一致）
*.kt     text eol=lf
*.kts    text eol=lf
*.java   text eol=lf
*.xml    text eol=lf
*.gradle text eol=lf
*.pro     text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.json   text eol=lf
*.properties text eol=lf
*.sh     text eol=lf
*.sql    text eol=lf
*.toml   text eol=lf

# Windows 专属脚本保持 CRLF
*.bat    text eol=crlf
*.cmd    text eol=crlf
*.ps1    text eol=crlf

# 二进制：不做任何转换
*.png    binary
*.jpg    binary
*.jpeg   binary
*.webp   binary
*.gif    binary
*.ico    binary
*.svg    text eol=lf
*.so     binary
*.aar    binary
*.jar    binary
*.zip    binary
*.gz     binary
*.jks    binary
*.keystore binary
*.bin    binary
